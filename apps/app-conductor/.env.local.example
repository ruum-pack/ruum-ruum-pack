# Copia este archivo a .env.local y llena los valores que imprime
# `pnpm db:start` (o tu proyecto de Supabase en la nube).
# Sin estas variables, la app sigue funcionando en "modo demo": las
# pantallas de Viajes y Ganancias muestran datos de ejemplo en vez de
# consultar la base real.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

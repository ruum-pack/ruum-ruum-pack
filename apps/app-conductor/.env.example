# Supabase publico para Next.js
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Version visible en telemetria/eventos de registro
NEXT_PUBLIC_APP_VERSION=

# Capacitor opcional para builds que apuntan a otro ambiente
RUUM_CAPACITOR_SERVER_URL=

# Mapbox: mapa estático de ruta hacia el punto de inicio (pantalla "Dirígete
# al punto de inicio"). Mismo token público (pk.) usado en panel-admin y
# app-usuario -- si no está configurado, la pantalla muestra solo la
# dirección en texto, sin mapa.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Contactos publicos de soporte.
# Produccion debe usar los canales oficiales. Staging/desarrollo deben usar
# valores de prueba y se mostraran marcados como "(pruebas)".
NEXT_PUBLIC_RUUM_AMBIENTE=staging
NEXT_PUBLIC_RUUM_SOPORTE_TELEFONO=5500000000
NEXT_PUBLIC_RUUM_SOPORTE_CORREO=soporte-conductores-pruebas@example.test
NEXT_PUBLIC_RUUM_EMERGENCIA_TELEFONO=5500000911

# Resend
RESEND_API_KEY=

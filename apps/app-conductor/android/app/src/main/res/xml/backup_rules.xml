<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- F5-10: allowBackup=false is the primary control. These defensive
         exclusions keep sensitive operational data out if backup is reopened. -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
</full-backup-content>

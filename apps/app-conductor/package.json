{
  "name": "@ruum/app-conductor",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "lint": "eslint .",
    "lint:a11y": "eslint . --ext .ts,.tsx --config eslint.config.mjs",
    "test": "vitest run",
    "test:a11y": "playwright test tests/a11y",
    "test:a11y:ui": "playwright test tests/a11y --ui",
    "test:lighthouse": "lhci autorun",
    "test:axe": "axe http://localhost:3001 --save results/axe-report.json",
    "audit:a11y": "node scripts/audit-a11y.mjs",
    "audit:a11y:route": "node scripts/audit-a11y.mjs --route",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@ruum/api": "workspace:*",
    "@ruum/shared": "workspace:*",
    "@ruum/ui": "workspace:*",
    "@supabase/supabase-js": "^2.47.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/cli": "^8.4.1",
    "@eslint/eslintrc": "^3.3.6",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-essentials": "^10.5.2",
    "@storybook/nextjs": "^10.5.2",
    "@storybook/react": "^10.5.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}

# Copia este archivo a .env.local y llena los valores que imprime
# `pnpm db:start` (o tu proyecto de Supabase en la nube).
# Sin estas variables, el panel sigue siendo navegable en "modo demo": el
# dashboard y las listas muestran datos de ejemplo en vez de consultar la
# base real.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

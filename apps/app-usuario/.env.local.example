# Copia este archivo a .env.local y llena los valores que imprime
# `pnpm db:start` (o tu proyecto de Supabase en la nube).
# Sin estas variables, la app sigue funcionando en "modo demo":
# /traslados/demo-0001 siempre muestra datos de ejemplo, y el wizard de
# /traslados/nuevo simula el envío en vez de guardar en la base real.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

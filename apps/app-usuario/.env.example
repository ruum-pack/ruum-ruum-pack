#stripe#
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

#Google Maps (Geocoding + Places para el wizard de traslados/nuevo)#
# Habilita Maps JavaScript API, Places API y Geocoding API en Google Cloud
# Console; restringe la key por HTTP referrer (web) y por package name/SHA-1
# o bundle ID (shell nativo Capacitor). Sin esto, origen/destino se guardan
# en 0,0 (ver lib/google-maps.ts).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

#Supabase#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
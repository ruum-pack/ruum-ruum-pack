{
  "name": "ruum-ruum",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm -r --workspace-concurrency=1 --filter \"./packages/*\" --filter \"./apps/*\" run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test --filter=./packages/*",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > packages/shared/src/types/supabase.ts",
    "typecheck:android": "pnpm -r run typecheck",
    "test:unit:android": "pnpm --filter \"./packages/*\" run test"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@types/node": "^22.10.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "turbo": "^2.10.5",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  }
}

# Dockerfile para DESARROLLO - con hot-reload para Next.js
# Este archivo está optimizado para desarrollo local con volúmenes montados
# Usa shamefully-hoist para tener node_modules centralizado
# syntax=docker/dockerfile:1

ARG NODE_VERSION=24
ARG PNPM_VERSION=10

################################################################################
# Stage: Desarrollo
################################################################################
FROM node:${NODE_VERSION}-alpine as dev

WORKDIR /app

# Configurar pnpm
RUN --mount=type=cache,target=/root/.npm \
    npm install -g pnpm@${PNPM_VERSION}

# Crear .npmrc con shamefully-hoist para node_modules centralizado
RUN echo "shamefully-hoist=true" > .npmrc

# Copiar archivos de configuración del workspace
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copiar TODOS los package.json de apps y packages
COPY apps/ ./apps/
COPY packages/ ./packages/

# Instalar TODAS las dependencias del monorepo
# Con shamefully-hoist, todas las dependencias van a /app/node_modules
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

# Copiar archivos de configuración adicionales
COPY turbo.json tsconfig.json deno.json deno.lock ./

# Crear directorios para las apps (necesario para los volúmenes)
RUN mkdir -p apps/app-conductor apps/app-usuario apps/panel-admin

# Exponer puertos
EXPOSE 3000 3001 3002

# Comando por defecto (se sobrescribe en docker-compose)
CMD ["pnpm", "run", "dev"]

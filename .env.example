# Ruum Monorepo Environment Variables
# Copy this file to .env and fill in the required values

# ============================================================================
# Common Variables
# ============================================================================

# Node environment
NODE_ENV=development

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase URL (local or remote)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================================================
# Application URLs
# ============================================================================

# App Conductor
NEXT_PUBLIC_APP_CONDUCTOR_URL=http://localhost:3001

# App Usuario  
NEXT_PUBLIC_APP_USUARIO_URL=http://localhost:3000

# Panel Admin
NEXT_PUBLIC_PANEL_ADMIN_URL=http://localhost:3002

# ============================================================================
# API Configuration
# ============================================================================

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================================================
# Capacitor / Mobile Configuration
# ============================================================================

# App ID for mobile
CAPACITOR_APP_ID=com.ruum.app

# ============================================================================
# Stripe Configuration (for app-usuario)
# ============================================================================

# Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# ============================================================================
# Mapbox Configuration (for panel-admin)
# ============================================================================

# Mapbox access token
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ============================================================================
# Security Configuration
# ============================================================================

# Session secret
SESSION_SECRET=your-session-secret-key-here

# JWT secret
JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# Database Configuration (for server-side)
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ============================================================================
# Docker Configuration
# ============================================================================

# Docker container ports
APP_CONDUCTOR_PORT=3001
APP_USUARIO_PORT=3000
PANEL_ADMIN_PORT=3002
